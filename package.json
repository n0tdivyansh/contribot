{
  "name": "contribot",
  "version": "0.1.0",
  "description": "A safe, configurable CLI for scanning codebases, applying constrained fixes, validating them, and opening pull requests.",
  "type": "module",
  "main": "./dist/src/cli/index.js",
  "bin": {
    "contribot": "./dist/src/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "contribot.config.example.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "dev": "node --loader ts-node/esm src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run build && npm test",
    "pack:dry": "npm pack --dry-run",
    "release:check": "npm run check && npm run pack:dry",
    "prepublishOnly": "npm run release:check"
  },
  "keywords": [
    "github",
    "cli",
    "automation",
    "oss",
    "pull-request",
    "lint",
    "formatter",
    "codebase"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vitest": "^4.1.3"
  }
}
